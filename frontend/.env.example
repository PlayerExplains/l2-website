# Backend API URL (local dev: leave empty to use Vite proxy, or set http://localhost:4001)
VITE_API_URL=http://localhost:4001

# External links — must restart dev server after changes (npm run dev)
# On Render: set on the static site, then redeploy so Vite rebuilds with new values
VITE_DISCORD_URL=https://discord.gg/your-invite
VITE_DOWNLOAD_URL=https://example.com/your-client-download

# Use #download to scroll to the download section on the homepage instead of an external URL
# VITE_DOWNLOAD_URL=#download
